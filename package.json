{
  "name": "open-agent",
  "version": "0.1.0",
  "description": "Open Agent — an open-source autonomous AI agent that runs locally. A self-hosted alternative to Manus.",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "openagent": "./bin/openagent.mjs"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "agent",
    "autonomous",
    "ai",
    "cli",
    "manus",
    "open-source"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fs-extra": "^11.2.0",
    "ink": "^5.0.1",
    "node-telegram-bot-api": "^0.66.0",
    "ora": "^8.1.0",
    "playwright": "^1.48.0",
    "react": "^18.3.1",
    "tsx": "^4.19.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.7.5",
    "@types/node-telegram-bot-api": "^0.64.7",
    "@types/react": "^18.3.11",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18"
  }
}
